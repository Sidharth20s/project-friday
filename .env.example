# FRIDAY AI Assistant — Environment Variables
# Copy this file to .env and fill in your values

# =============================
# REQUIRED: Google Gemini API Key
# Get yours FREE at: https://aistudio.google.com/
# =============================
GEMINI_API_KEY=your_gemini_api_key_here

# =============================
# OPTIONAL: Weather (OpenWeatherMap)
# Get yours FREE at: https://openweathermap.org/api
# =============================
WEATHER_API_KEY=your_openweathermap_key_here
DEFAULT_CITY=New Delhi

# =============================
# OPTIONAL: Assistant Settings
# =============================
WAKE_WORD=hey friday
ASSISTANT_NAME=Friday
VOICE_SPEED=175
VOICE_VOLUME=1.0
