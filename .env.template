# FRIDAY Configuration Template
# INSTRUCTIONS:
# 1. Copy this file content to create a new .env file
# 2. Replace placeholder values with your actual settings
# 3. Never share your .env file (contains API keys)

# ═════════════════════════════════════════════════════════════════
# REQUIRED API KEYS
# ═════════════════════════════════════════════════════════════════

# Google Gemini API Key (REQUIRED for AI)
# Get from: https://aistudio.google.com/app/apikey
# Example: AIzaSyDm9X_Z...
GEMINI_API_KEY=your_gemini_api_key_here

# ═════════════════════════════════════════════════════════════════
# OPTIONAL API KEYS
# ═════════════════════════════════════════════════════════════════

# OpenWeather API Key (for weather feature)
# Get from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ═════════════════════════════════════════════════════════════════
# WEB SERVER SETTINGS
# ═════════════════════════════════════════════════════════════════

WEB_PORT=5000
WEB_HOST=127.0.0.1

# ═════════════════════════════════════════════════════════════════
# ASSISTANT SETTINGS
# ═════════════════════════════════════════════════════════════════

ASSISTANT_NAME=FRIDAY
PERSONALITY=sarcastic
MEMORY_LIMIT=50

# ═════════════════════════════════════════════════════════════════
# WINDOWS SERVICE SETTINGS
# ═════════════════════════════════════════════════════════════════

AUTO_START_ENABLED=true
GLOBAL_HOTKEY=ctrl+alt+f
TRAY_ICON_ENABLED=true

# ═════════════════════════════════════════════════════════════════
# FEATURE TOGGLES
# ═════════════════════════════════════════════════════════════════

FEATURE_CALENDAR=true
FEATURE_NOTES=true
FEATURE_WEATHER=true
FEATURE_SYSTEM_MONITOR=true
FEATURE_APP_CONTROL=true
FEATURE_AUTOMATIONS=true

# ═════════════════════════════════════════════════════════════════
# VOICE & AUDIO
# ═════════════════════════════════════════════════════════════════

VOICE_OUTPUT_ENABLED=true
SPEECH_LANGUAGE=en-US
MICROPHONE_DEVICE=

# ═════════════════════════════════════════════════════════════════
# LOGGING
# ═════════════════════════════════════════════════════════════════

LOG_LEVEL=INFO
LOG_DIR=logs
